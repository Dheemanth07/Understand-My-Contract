{
  "name": "understand-my-contract-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Understand My Contract - AI-Powered Legal Document Simplification",
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "start:backend": "npm start --prefix backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run start:backend\"",
    "test:backend": "npm test --prefix backend",
    "test:frontend": "npm test --prefix frontend",
    "typecheck:frontend": "npm run typecheck --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "validate:config": "npm run validate:config --prefix frontend",
    "validate:env": "npm run validate:env --prefix frontend --",
    "test:build": "npm run test:build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "typecheck": "npm run typecheck --prefix frontend",
    "test:ci": "npm run test:ci --prefix frontend",
    "test:e2e": "npm run test:e2e --prefix frontend --",
    "build": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "mongodb": "^7.3.0",
    "mongoose": "^9.7.1"
  }
}
