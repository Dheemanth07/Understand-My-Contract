{
  "name": "understand-my-contract-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Understand My Contract - AI-Powered Legal Document Simplification",
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "start:backend": "npm start --prefix backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run start:backend\"",
    "test:backend": "npm test --prefix backend",
    "test:frontend": "npm test --prefix frontend",
    "typecheck:frontend": "npm run typecheck --prefix frontend",
    "build:frontend": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
